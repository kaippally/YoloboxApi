# YoloBox Ultra REST-to-WebSocket Relay API
# Configuration for the middleware service

# Port for the Express API server
PORT=3000

# Static local IP address of the target YoloBox Ultra
YOLOBOX_IP=192.168.1.100

# WebSocket port on the YoloBox (default is 8887)
WS_PORT=8887

# WebSocket reconnection interval in milliseconds (default: 5000ms)
RECONNECT_INTERVAL=5000
